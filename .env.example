# ─────────────────────────────────────────────────────────────
#  SSH Sentinel — Environment Configuration
#  Copy to .env and edit before running.
#  Never commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ── Dashboard auth ────────────────────────────────────────────
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=changeme          # CHANGE THIS!
SECRET_KEY=                          # Auto-generated by setup.sh if blank

# ── Dashboard server ──────────────────────────────────────────
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=5000

# ── Honeypot ports (high ports, no root required) ─────────────
SSH_PORT=2222
FTP_PORT=2121
HTTP_PORT=8080
TELNET_PORT=2323
MYSQL_PORT=3307
REDIS_PORT=6380
SMTP_PORT=2525

# ── Storage ───────────────────────────────────────────────────
DB_PATH=honeypot.db
LOG_FILE=sentinel.log

# ── SSH host key ──────────────────────────────────────────────
HOST_KEY_PATH=honeypot_host_key

# ── Rate limiting ─────────────────────────────────────────────
MAX_CONN_PER_IP=30        # max connections per IP per 60 seconds
BAN_THRESHOLD=100         # auto-ban after N total events from same IP

# ── Geolocation cache ─────────────────────────────────────────
GEO_CACHE_HOURS=24

# ── Email alerts (optional) ───────────────────────────────────
# Leave ALERT_EMAIL blank to disable
ALERT_EMAIL=
SMTP_ALERT_HOST=smtp.gmail.com
SMTP_ALERT_PORT=587
SMTP_USER=
SMTP_PASS=                           # Use an app-specific password for Gmail
ALERT_THRESHOLD=10                   # Send alert after N events from same IP

# ── Fake server banners ───────────────────────────────────────
SSH_BANNER=SSH-2.0-OpenSSH_8.2p1 Ubuntu-4ubuntu0.9
FTP_BANNER=220 (vsFTPd 3.0.3)
MYSQL_VERSION=5.7.42-log
HTTP_SERVER=Apache/2.4.52 (Ubuntu)

# ── Flask debug (set true only in development) ────────────────
FLASK_DEBUG=false
